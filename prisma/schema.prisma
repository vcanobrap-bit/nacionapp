// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  Enums
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  PLAYER
}

enum MatchStatus {
  PENDING      // Por jugar
  IN_PROGRESS  // En curso (partido en vivo)
  FINISHED     // Finalizado
}

enum MatchResult {
  WIN
  LOSS
  DRAW
}

/// Estado físico/disponibilidad de la jugadora (solo visible para admin)
enum PlayerStatus {
  AVAILABLE
  INJURED
}

/// Tipo de incidencia en el partido
enum EventType {
  GOAL     // Gol
  AMARILLA // Tarjeta amarilla
  ROJA     // Tarjeta roja
  CAMBIO   // Sustitución
}

// ─────────────────────────────────────────────
//  Models
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Datos personales de la jugadora (relación 1:1)
  profile   Profile?

  /// Partidos en los que esta jugadora participó
  playerMatches PlayerMatch[]

  /// Partidos creados/administrados por este usuario
  createdMatches Match[] @relation("CreatedBy")

  /// Incidencias de partido donde esta jugadora fue protagonista
  matchEvents  MatchEvent[] @relation("MatchEvents")
  /// Incidencias donde esta jugadora entra (sustituciones)
  matchEvents2 MatchEvent[] @relation("MatchEvents2")

  @@map("users")
}

model Profile {
  id           String       @id @default(cuid())
  userId       String       @unique

  // ── Campos públicos ─────────────────────────
  firstName    String
  lastName     String
  avatarUrl    String?      // URL de la foto de perfil
  birthdate    DateTime?    // Fecha de nacimiento
  joiningYear  Int?         // Año en que se incorporó a la selección
  idealPosition String?     // ej. "Delantera", "Mediocampista", "Defensora", "Portera"
  number       Int?         // Número de camiseta
  nationality  String?      @default("Argentina")
  bio          String?      // Descripción pública breve

  // ── Campos privados (solo admin) ────────────
  status         PlayerStatus @default(AVAILABLE)
  adminComments  String?      // Notas internas del cuerpo técnico

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Tournament {
  id        String   @id @default(cuid())
  name      String
  year      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  matches Match[]

  @@map("tournaments")
}

model Match {
  id        String      @id @default(cuid())
  date      DateTime
  opponent  String      // Nombre del equipo rival
  venue     String?     // Estadio / cancha
  status    MatchStatus @default(PENDING)
  result    MatchResult?          // null mientras status != FINISHED
  homeScore Int?                  // Goles propios
  awayScore Int?                  // Goles del rival
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // ── Torneo / Fixture ──────────────────────────
  tournamentId       String?  // FK a Tournament (opcional)
  round              Int?     // Rueda (1, 2, …) — solo torneos con ruedas
  fixtureRoundNumber Int?     // Número de fecha dentro de la rueda (ej: 5)

  createdById String
  createdBy   User       @relation("CreatedBy", fields: [createdById], references: [id])

  tournament  Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  /// Jugadoras convocadas / que participaron en el partido
  players     PlayerMatch[]

  /// Incidencias del partido (goles, tarjetas)
  events      MatchEvent[]

  @@map("matches")
}

/// Incidencia registrada durante un partido en vivo
model MatchEvent {
  id        String    @id @default(cuid())
  matchId   String
  type      EventType
  /// true = nuestro equipo, false = rival (solo relevante para GOAL)
  isOwn     Boolean   @default(true)
  /// Jugadora principal: autora del gol/tarjeta; o la que Sale en un CAMBIO
  playerId  String?
  /// Solo para CAMBIO: la jugadora que Entra
  player2Id String?
  minute    Int?
  createdAt DateTime  @default(now())

  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player  User? @relation("MatchEvents",  fields: [playerId],  references: [id], onDelete: SetNull)
  player2 User? @relation("MatchEvents2", fields: [player2Id], references: [id], onDelete: SetNull)

  @@map("match_events")
}

/// Tabla intermedia: convocatoria y titularidad por partido
model PlayerMatch {
  id        String  @id @default(cuid())
  userId    String
  matchId   String

  /// true = jugadora titular en este partido (se setea cuando pasa a IN_PROGRESS)
  isTitular Boolean @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@map("player_matches")
}
